{
  "name": "digilompakko",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source EUDI-compliant digital identity wallet demo (issuer + wallet + verifier), aligned with the EU ARF and OpenID4VC HAIP 1.0.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "prepare": "tsc --build packages/core",
    "test": "node --test --import tsx packages/core/test/*.test.ts",
    "predemo": "tsc --build packages/core",
    "demo": "tsx scripts/demo.ts",
    "prestart": "tsc --build packages/core",
    "issuer": "tsx apps/issuer/src/server.ts",
    "verifier": "tsx apps/verifier/src/server.ts",
    "wallet": "tsx apps/wallet/src/server.ts",
    "start": "concurrently -n issuer,verifier,wallet -c green,magenta,cyan \"npm:issuer\" \"npm:verifier\" \"npm:wallet\""
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
